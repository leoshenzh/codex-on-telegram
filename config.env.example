# Codex on Telegram Bridge Configuration
# Copy to ~/.claude-to-im/config.env and edit

# Runtime backend: claude | codex | auto
CTI_RUNTIME=claude

# This build keeps Telegram only.
CTI_ENABLED_CHANNELS=telegram

# Default working directory for Claude Code / Codex sessions
CTI_DEFAULT_WORKDIR=/path/to/your/project

# Default model (optional — inherits from runtime's own default if not set)
# CTI_DEFAULT_MODEL=

# Claude thinking effort (effective only when this install runs CTI_RUNTIME=claude as fallback)
# CTI_CLAUDE_EFFORT=high

# Default mode (code, plan, ask)
CTI_DEFAULT_MODE=code

# Optional Claude CLI override
# CTI_CLAUDE_CODE_EXECUTABLE=/path/to/claude
# Claude CLI setting sources. Default loads normal user/project/local settings,
# including enabled plugins such as codex@openai-codex.
# Set to "none" only for SDK isolation.
# Only use project/local settings from directories you trust; /cwd into an
# unfamiliar repo can load that repo's Claude settings, hooks, MCP, and plugins.
# CTI_CLAUDE_SETTING_SOURCES=user,project,local
# Optional extra Claude plugin directories for this bridge session.
# CTI_CLAUDE_PLUGIN_DIRS=/path/to/plugin-a,/path/to/plugin-b

# Optional Codex runtime overrides
# CTI_CODEX_PASS_MODEL=true
# CTI_CODEX_SKIP_GIT_REPO_CHECK=true
# CTI_CODEX_APPROVAL_POLICY=never
# CTI_CODEX_SANDBOX_MODE=danger-full-access
# CTI_CODEX_MODEL_REASONING_EFFORT=high
# CTI_CODEX_NETWORK_ACCESS_ENABLED=true
# CTI_CODEX_ADDITIONAL_DIRECTORIES=/,$HOME
# CTI_CODEX_STARTUP_IDLE_MS=30000
# CTI_CODEX_TERMINAL_IDLE_MS=1500

# ── Telegram ──
# Required for Telegram bridge access
# CTI_TG_BOT_TOKEN=123456:telegram-bot-token
# Optional default chat to notify / restrict to
# CTI_TG_CHAT_ID=123456789
# Allowed Telegram user/chat IDs (comma-separated).
# For owner-only use, keep this set to your Telegram user ID.
# CTI_TG_ALLOWED_USERS=123456789
# Stronger owner-only lock.
# Keep this set to your Telegram user ID for the current deployment model.
# CTI_TG_OWNER_USER_ID=123456789
# Keep Telegram open to groups/topics for the owner.
# Set to true only if you want private chat only.
CTI_TG_REQUIRE_PRIVATE_CHAT=false
# Group use also requires BotFather privacy mode to be disabled for the bot.
# In topic-enabled groups, each topic gets its own separate session.

# ── Permission ──
# Auto-approve all tool permission requests without user confirmation.
# CTI_AUTO_APPROVE=true
