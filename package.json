{
  "name": "codex-on-telegram",
  "version": "0.1.0",
  "description": "Codex on Telegram: a Telegram bridge for Claude/Codex coding sessions",
  "type": "module",
  "files": [
    "AGENTS.md",
    "SKILL.md",
    "config.env.example",
    "dist",
    "plan.md",
    "scripts",
    "src"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/main.ts",
    "test": "CTI_HOME=$(mktemp -d) node --test --test-concurrency=1 --import tsx --test-timeout=15000 src/__tests__/*.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.62",
    "claude-to-im": "file:./lib"
  },
  "optionalDependencies": {
    "@openai/codex-sdk": "^0.124.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
